	"components": {
		"parameters": {
			"ProjectId": {
				"name": "id",
				"in": "path",
				"required": true,
				"schema": {
					"type": "integer",
					"example": 1
				}
			},
			"TaskId": {
				"name": "taskId",
				"in": "path",
				"required": true,
				"schema": {
					"type": "integer",
					"example": 10
				}
			},
			"TagId": {
				"name": "tagId",
				"in": "path",
				"required": true,
				"schema": {
					"type": "integer",
					"example": 3
				}
			},
			"UserId": {
				"name": "id",
				"in": "path",
				"required": true,
				"schema": {
					"type": "integer",
					"example": 2
				}
			}
		},
		"responses": {
			"ValidationError": {
				"description": "Erro de validação",
				"content": {
					"application/json": {
						"schema": {
							"type": "object",
							"properties": {
								"message": {
									"type": "string",
									"example": "The given data was invalid."
								},
								"errors": {
									"type": "object",
									"additionalProperties": {
										"type": "array",
										"items": {
											"type": "string"
										}
									}
								}
							},
							"required": [
								"message",
								"errors"
							]
						}
					}
				}
			},
			"ProjectData": {
				"description": "Projeto encontrado",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/DataProjectResponse"
						}
					}
				}
			},
			"NotFoundProjeto": {
				"description": "Projeto não encontrado",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/ErrorWithStatus"
						},
						"examples": {
							"notFound": {
								"value": {
									"message": "Projeto não encontrado.",
									"status": 404
								}
							}
						}
					}
				}
			},
			"NotFoundTarefa": {
				"description": "Tarefa não encontrada",
				"content": {
					"application/json": {
						"schema": {
							"allOf": [
								{
