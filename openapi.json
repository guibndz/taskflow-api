					"200": {
						"description": "Lista de projetos",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"data": {
											"type": "array",
											"items": {
												"$ref": "#/components/schemas/Project"
											}
										}
									},
									"required": [
										"data"
									]
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": [
					"Projects"
				],
				"summary": "Criar projeto",
				"operationId": "createProject",
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/ProjectCreateRequest"
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Projeto criado",
						"content": {
							"application/json": {
								"schema": {
									"allOf": [
										{
											"$ref": "#/components/schemas/DataProjectResponse"
										},
										{
											"type": "object",
											"properties": {
												"message": {
													"type": "string",
													"example": "Projeto criado com sucesso."
												}
											},
											"required": [
												"message"
											]
										}
									]
								}
							}
						}
					},
					"422": {
						"$ref": "#/components/responses/ValidationError"
					}
				}
			}
		},
