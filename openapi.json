								}
							]
						},
						"examples": {
							"notFound": {
								"value": {
									"message": "Tarefa não encontrada."
								}
							}
						}
					}
				}
			},
			"NotFoundTarefaProjeto": {
				"description": "Tarefa não encontrada no projeto",
