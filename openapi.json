				],
				"summary": "Atualizar somente status da tarefa",
				"operationId": "updateTaskStatusInProject",
				"parameters": [
					{
						"$ref": "#/components/parameters/ProjectId"
					},
					{
						"$ref": "#/components/parameters/TaskId"
					}
