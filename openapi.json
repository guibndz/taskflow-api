							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"message": {
											"type": "string",
											"example": "Projeto excluído com sucesso."
										}
									},
									"required": [
										"message"
									]
								}
							}
						}
					},
					"404": {
						"$ref": "#/components/responses/NotFoundProjeto"
					}
