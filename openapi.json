					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/ErrorWithStatus"
						},
						"examples": {
							"notFound": {
								"value": {
									"message": "Tarefa não encontrada neste projeto.",
									"status": 404
								}
							}
						}
					}
				}
			},
			"NotFoundPerfil": {
				"description": "Perfil não encontrado",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/ErrorWithStatus"
						},
						"examples": {
							"notFound": {
								"value": {
									"message": "Perfil não encontrado.",
									"status": 404
								}
							}
						}
