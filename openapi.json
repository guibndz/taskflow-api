		"/tasks/{taskId}/tags/{tagId}": {
			"post": {
				"tags": [
					"TaskTag"
				],
				"summary": "Associar tag a tarefa",
				"operationId": "attachTagToTask",
				"parameters": [
					{
						"$ref": "#/components/parameters/TaskId"
					},
					{
						"$ref": "#/components/parameters/TagId"
					}
				],
				"responses": {
					"200": {
						"description": "Tag associada",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/MessageResponse"
								},
								"examples": {
									"success": {
										"value": {
											"message": "Tag associada com sucesso!"
										}
									}
								}
							}
						}
					},
					"404": {
						"$ref": "#/components/responses/NotFoundTarefa"
					},
					"409": {
						"description": "Conflito ao associar tag",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/MessageResponse"
								},
								"examples": {
									"alreadyAttached": {
										"value": {
											"message": "Esta tag já está associada a esta tarefa."
										}
									}
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": [
					"TaskTag"
				],
				"summary": "Remover tag da tarefa",
				"operationId": "detachTagFromTask",
				"parameters": [
					{
						"$ref": "#/components/parameters/TaskId"
					},
					{
						"$ref": "#/components/parameters/TagId"
					}
				],
				"responses": {
					"200": {
						"description": "Tag removida",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/MessageResponse"
								},
								"examples": {
									"success": {
										"value": {
											"message": "Tag removida com sucesso."
										}
									}
								}
							}
						}
					},
					"404": {
						"$ref": "#/components/responses/NotFoundTarefa"
					}
				}
			}
		},
